# TASM / TLINK build artifacts
*.OBJ
*.obj
EXAMPLES/*.EXE
*.MAP
*.map
*.LST
*.lst
*.bak

# editor / OS noise
*~
Thumbs.db
.DS_Store

# js-dos bundle staging (the final docs/city.jsdos IS committed for Pages)
docs/.bundle/
docs/city.zip
/.vs

# never let secrets reach the public repo (safety net for git add -A)
.env
.env.*
*.key
*.pem
*.pfx
*.p12
*secret*
*token*
*password*
credentials*

# generated at build time inside SRC (the INSTALL copies ARE committed:
# they are the playable release)
SRC/CITY.DAT
BUILD.LOG
stdout.txt
stderr.txt
GAMES/OWLFLY/res/panel1.psd
LOCAL.BAT

# Wavefront MODELS are sources, not TLINK artifacts - un-ignore them
# (the global *.obj above catches TASM output; res/ holds Blender exports)
!GAMES/*/res/*.obj
!TOOLS/TRAINER.OBJ

# Debug harness: keep the folders, drop the noise (shots, flight logs,
# the compiled exe); sources and scenarios stay tracked
Debug/shots/*
!Debug/shots/.gitkeep
Debug/log/*
!Debug/log/.gitkeep
Debug/FlyDbg.exe

<Window x:Class="WireCityChat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WIRE CITY CHAT OPERATOR" Height="560" Width="820"
        Background="#04060F">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="HeaderText" Foreground="#88AAFF"
                   FontFamily="Consolas" FontSize="14" Margin="0,0,0,8"
                   Text="starting..." />

        <ListBox Grid.Row="1" x:Name="ChatList" Background="#0A0E1A" Foreground="#BBCCDD"
                 FontFamily="Consolas" FontSize="14" BorderBrush="#223355"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="4,1" />
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="InputBox" Background="#0A0E1A" Foreground="#DDEEFF"
                     FontFamily="Consolas" FontSize="14" BorderBrush="#223355"
                     KeyDown="InputBox_KeyDown" />
            <Button Grid.Column="1" Content="SEND" Width="80" Margin="8,0,0,0"
                    Background="#223355" Foreground="#DDEEFF" BorderBrush="#4466AA"
                    Click="SendButton_Click" />
        </Grid>

        <TextBlock Grid.Row="3" x:Name="StatusText" Foreground="#667799"
                   FontFamily="Consolas" FontSize="12" Margin="0,8,0,0"
                   Text="" TextWrapping="Wrap" />
    </Grid>
</Window>
